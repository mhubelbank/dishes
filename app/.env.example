# Local secrets for Node-side scripts (future: the Walmart scraper, eval/batch jobs).
# Copy to .env.local and fill in:
#
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real keys. The APP ITSELF does NOT use
# this file: keys live in browser localStorage (BYO-key model, see architecture.md).
# Real environment variables take precedence over anything set here.

# Anthropic key for the language-shaped tasks (auto-tag, receipt OCR, "why", mood).
ANTHROPIC_API_KEY=

# Classic repo-scoped GitHub token for the private dishes-data repo (git-as-DB).
# Used by Node scripts; the app prompts for its own token in Settings.
GITHUB_TOKEN=
